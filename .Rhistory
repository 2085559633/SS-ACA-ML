suppressPackageStartupMessages({
library(tidyverse)
})
train_path <- "all_train_results.csv"
val_path   <- "all_val_results.csv"
# =========================
# 1) 读取数据 & 统一列名
# =========================
train <- readr::read_csv(train_path, show_col_types = FALSE)
val   <- readr::read_csv(val_path,   show_col_types = FALSE)
# 统一：第一列 = Label
names(train)[1] <- "Label"
names(val)[1]   <- "Label"
# 标签必须是 0/1（若是因子/字符会自动转数值）
coerce_label01 <- function(x) {
if (is.logical(x)) return(as.integer(x))
if (is.factor(x))  x <- as.character(x)
x <- as.numeric(x)
if (!all(x %in% c(0, 1), na.rm = TRUE)) {
stop("Label 不是 0/1。请先把标签改成 0/1，再运行脚本。当前唯一值：",
paste(sort(unique(x)), collapse = ", "))
}
as.integer(x)
}
train$Label <- coerce_label01(train$Label)
val$Label   <- coerce_label01(val$Label)
# 模型列：除 Label 外全部视为“预测概率列”
model_cols <- setdiff(names(train), "Label")
# 若训练/验证的模型列不一致，提前报错（避免画错）
if (!setequal(model_cols, setdiff(names(val), "Label"))) {
stop("训练集与验证集的模型列不一致，请检查两份表的列名。")
}
# 可选：给模型更友好的显示名（按你当前列名写的映射；不匹配则保持原名）
model_label_map <- c(
rf_proba   = "Random Forest",
lr_proba   = "Logistic Regression",
gbdt_proba = "GBDT",
ada_proba  = "AdaBoost",
xgb_proba  = "XGBoost",
lgbm_proba = "LightGBM"
)
# =========================
# 2) 配色：6色（好看、区分度高）
# =========================
pal6 <- c(
"#1B9E77", # teal
"#D95F02", # orange
"#7570B3", # purple
"#E7298A", # magenta
"#66A61E", # green
"#E6AB02"  # mustard
)
# 按模型列顺序命名颜色
pal_named <- setNames(pal6[seq_along(model_cols)], model_cols)
# =========================
# 3) 校准曲线（分箱法：按预测概率分10箱）
# =========================
make_calibration_df <- function(df, dataset_name, n_bins = 10) {
df %>%
mutate(dataset = dataset_name) %>%
pivot_longer(cols = all_of(model_cols), names_to = "model", values_to = "pred") %>%
mutate(
pred = as.numeric(pred),
model_show = dplyr::recode(model, !!!model_label_map, .default = model)
) %>%
group_by(dataset, model, model_show) %>%
# 用分位数分箱（每箱样本量尽量均衡）
mutate(bin = dplyr::ntile(pred, n_bins)) %>%
group_by(dataset, model, model_show, bin) %>%
summarise(
mean_pred = mean(pred, na.rm = TRUE),
obs_rate  = mean(Label, na.rm = TRUE),
n         = dplyr::n(),
.groups = "drop"
)
}
calib_train <- make_calibration_df(train, "Train", n_bins = 10)
calib_val   <- make_calibration_df(val,   "Validation", n_bins = 10)
calib_all   <- bind_rows(calib_train, calib_val)
p_calib <- ggplot(calib_all, aes(x = mean_pred, y = obs_rate, color = model, group = model)) +
geom_abline(slope = 1, intercept = 0, linetype = "dashed", linewidth = 0.8, color = "grey50") +
geom_line(linewidth = 1.0) +
geom_point(size = 2.2) +
facet_wrap(~ dataset, nrow = 1) +
scale_color_manual(
values = pal_named,
breaks = model_cols,
labels = dplyr::recode(model_cols, !!!model_label_map, .default = model_cols),
name = "Model"
) +
coord_equal(xlim = c(0, 1), ylim = c(0, 1)) +
labs(
title = "Calibration Curves (Train vs Validation)",
x = "Mean predicted probability",
y = "Observed event rate"
) +
theme_minimal(base_size = 13) +
theme(
legend.position = "bottom",
panel.grid.minor = element_blank()
)
# =========================
# 4) DCA（手动实现：不依赖额外包）
# =========================
calc_dca <- function(df, dataset_name, thresholds = seq(0.01, 0.99, by = 0.01)) {
y <- coerce_label01(df$Label)
n <- length(y)
# 参考线：Treat All / Treat None
tp_all <- sum(y == 1, na.rm = TRUE)
fp_all <- sum(y == 0, na.rm = TRUE)
dca_ref <- tibble(
threshold = rep(thresholds, 2),
model = rep(c("Treat All", "Treat None"), each = length(thresholds)),
net_benefit = c(
(tp_all / n) - (fp_all / n) * (thresholds / (1 - thresholds)),
rep(0, length(thresholds))
),
dataset = dataset_name
)
# 各模型 NB
dca_models <- map_dfr(model_cols, function(m) {
p <- as.numeric(df[[m]])
tibble(
threshold = thresholds,
model = m,
net_benefit = map_dbl(thresholds, function(t) {
pred_pos <- p >= t
TP <- sum(pred_pos & (y == 1), na.rm = TRUE)
FP <- sum(pred_pos & (y == 0), na.rm = TRUE)
(TP / n) - (FP / n) * (t / (1 - t))
}),
dataset = dataset_name
)
})
bind_rows(dca_models, dca_ref) %>%
mutate(model_show = dplyr::recode(model, !!!model_label_map, .default = model))
}
dca_train <- calc_dca(train, "Train", thresholds = seq(0.01, 0.99, by = 0.01))
dca_val   <- calc_dca(val,   "Validation", thresholds = seq(0.01, 0.99, by = 0.01))
dca_all   <- bind_rows(dca_train, dca_val)
# 颜色：6模型 + 2参考线
dca_colors <- c(
pal_named,
"Treat All"  = "grey35",
"Treat None" = "grey70"
)
dca_linetype <- c(
setNames(rep("solid", length(model_cols)), model_cols),
"Treat All"  = "dashed",
"Treat None" = "dotted"
)
p_dca <- ggplot(dca_all, aes(x = threshold, y = net_benefit, color = model, linetype = model)) +
geom_hline(yintercept = 0, linewidth = 0.6, color = "grey60") +
geom_line(linewidth = 1.0) +
facet_wrap(~ dataset, nrow = 1) +
scale_color_manual(
values = dca_colors,
breaks = c(model_cols, "Treat All", "Treat None"),
labels = c(
dplyr::recode(model_cols, !!!model_label_map, .default = model_cols),
"Treat All", "Treat None"
),
name = "Model"
) +
scale_linetype_manual(
values = dca_linetype,
breaks = c(model_cols, "Treat All", "Treat None"),
guide = "none"
) +
labs(
title = "Decision Curve Analysis (Train vs Validation)",
x = "Threshold probability",
y = "Net benefit"
) +
theme_minimal(base_size = 13) +
theme(
legend.position = "bottom",
panel.grid.minor = element_blank()
) +
coord_cartesian(xlim = c(0, 0.8))  # 常用阈值范围；如需全范围改成 c(0, 1)
# =========================
# 5) 展示 & 保存
# =========================
print(p_calib)
print(p_dca)
ggsave("Calibration_Train_vs_Validation.png", p_calib, width = 11, height = 4.2, dpi = 300)
ggsave("DCA_Train_vs_Validation.png",         p_dca,   width = 11, height = 4.2, dpi = 300)
