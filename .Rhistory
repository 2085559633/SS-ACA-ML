dca_train <- calc_dca(train, "Train", thresholds = seq(0.01, 0.99, by = 0.01))
dca_val   <- calc_dca(val,   "Validation", thresholds = seq(0.01, 0.99, by = 0.01))
dca_all   <- bind_rows(dca_train, dca_val)
# 颜色：6模型 + 2参考线
dca_colors <- c(
pal_named,
"Treat All"  = "grey35",
"Treat None" = "grey70"
)
dca_linetype <- c(
setNames(rep("solid", length(model_cols)), model_cols),
"Treat All"  = "dashed",
"Treat None" = "dotted"
)
p_dca <- ggplot(dca_all, aes(x = threshold, y = net_benefit, color = model, linetype = model)) +
geom_hline(yintercept = 0, linewidth = 0.6, color = "grey60") +
geom_line(linewidth = 1.0) +
facet_wrap(~ dataset, nrow = 1) +
scale_color_manual(
values = dca_colors,
breaks = c(model_cols, "Treat All", "Treat None"),
labels = c(
dplyr::recode(model_cols, !!!model_label_map, .default = model_cols),
"Treat All", "Treat None"
),
name = "Model"
) +
scale_linetype_manual(
values = dca_linetype,
breaks = c(model_cols, "Treat All", "Treat None"),
guide = "none"
) +
labs(
title = "Decision Curve Analysis (Train vs Validation)",
x = "Threshold probability",
y = "Net benefit"
) +
theme_minimal(base_size = 13) +
theme(
legend.position = "bottom",
panel.grid.minor = element_blank()
) +
coord_cartesian(xlim = c(0, 0.8))  # 常用阈值范围；如需全范围改成 c(0, 1)
print(p_dca)
p_calib <- ggplot(calib_all, aes(x = mean_pred, y = obs_rate, color = model, group = model)) +
geom_abline(slope = 1, intercept = 0, linetype = "dashed", linewidth = 0.8, color = "grey50") +
geom_line(linewidth = 1.0) +
geom_point(size = 2.2) +
facet_wrap(~ dataset, nrow = 1) +
scale_color_manual(
values = pal_named,
breaks = model_cols,
labels = dplyr::recode(model_cols, !!!model_label_map, .default = model_cols),
name = "Model"
) +
coord_equal(xlim = c(0, 0.5), ylim = c(0, 0.75)) +
labs(
title = "Calibration Curves (Train vs Validation)",
x = "Mean predicted probability",
y = "Observed event rate"
) +
theme_minimal(base_size = 13) +
theme(
legend.position = "bottom",
panel.grid.minor = element_blank()
)
p_calib
